# =============================================================================
# VideoForge Pro - Configuration Example (نسخه template آمناً لـ GitHub)
# =============================================================================
# انسخ هذا الملف إلى .env واملأ المفاتيح الخاصة بك

# --- Sync.so API (السحابي) ---
SYNC_API_KEY=your_sync_api_key_here

# --- Pexels API (للمقاطع والصورة) ---
PEXELS_API_KEY=your_pexels_api_key_here

# --- Google AdSense (للربح من الإعلانات) ---
ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxx
ADSENSE_SLOT_TOP=
ADSENSE_SLOT_SIDEBAR=
ADSENSE_SLOT_IN_ARTICLE=
ADSENSE_SLOT_VIDEO=

# --- Google Analytics (لتتبع الزوار) ---
GA_TRACKING_ID=G-XXXXXXXXXX

# --- Secret Key (لجلسات Flask) ---
SECRET_KEY=change-this-to-a-random-secret-key

# --- Server Settings ---
PORT=5000
